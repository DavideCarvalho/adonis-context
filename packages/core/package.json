{
  "name": "@adonis-agora/context",
  "version": "0.1.0",
  "description": "Shared AsyncLocalStorage context for AdonisJS — carries user/tenant/traceId across the request and the Agora ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/adonis-context.git",
    "directory": "packages/core"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing/index.d.ts",
      "import": "./dist/src/testing/index.js",
      "default": "./dist/src/testing/index.js"
    },
    "./context_provider": {
      "types": "./dist/providers/context_provider.d.ts",
      "import": "./dist/providers/context_provider.js",
      "default": "./dist/providers/context_provider.js"
    },
    "./context_middleware": {
      "types": "./dist/src/context_middleware.d.ts",
      "import": "./dist/src/context_middleware.js",
      "default": "./dist/src/context_middleware.js"
    },
    "./configure": {
      "types": "./dist/configure.d.ts",
      "import": "./dist/configure.js",
      "default": "./dist/configure.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "//sideEffects": "NOT false: context.ts holds the module-level singleton (AsyncLocalStorage + cross-boundary config), define_config.ts holds the middleware's population-options holder, and accessor.ts publishes the accessor on a Symbol.for() global slot AT IMPORT TIME (the ecosystem decoupling contract other libs read). All are process-global state a bundler told sideEffects:false could tree-shake. Pure modules (index, traceparent, baggage, middleware, provider) stay tree-shakeable.",
  "sideEffects": [
    "**/context.js",
    "**/context.ts",
    "**/define_config.js",
    "**/define_config.ts",
    "**/accessor.js",
    "**/accessor.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy:stubs",
    "copy:stubs": "mkdir -p dist/stubs/config && cp stubs/config/context.stub dist/stubs/config/context.stub",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6.12.0"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.0",
    "@adonisjs/core": "^6.17.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "keywords": [
    "adonisjs",
    "adonis",
    "context",
    "async-local-storage",
    "als",
    "trace",
    "tenant",
    "agora"
  ]
}
